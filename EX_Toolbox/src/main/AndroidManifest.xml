<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"

    android:versionCode="51"
    android:versionName="0.1.35" android:installLocation="auto">

    <uses-sdk tools:overrideLibrary="androidx.appcompat.resources,             androidx.appcompat, androidx.core.ktx, androidx.core,             androidx.annotation.experimental" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
<!--    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />-->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.VIBRATE" />
<!--    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />-->
<!--    <uses-permission android:name="android.permission.WRITE_SETTINGS"  tools:ignore="ProtectedPermissions"/>-->
<!-- needed for API 34 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
<!-- needed for API 34 -->
    <supports-screens
        android:largeScreens="true"
        android:normalScreens="true"
        android:resizeable="true"
        android:smallScreens="true" />
    <uses-permission android:name="android.permission.READ_LOGS" tools:ignore="ProtectedPermissions"/>
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" />
<!--    <uses-permission android:name="android.permission.mod"/>-->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name="dcc_ex.ex_toolbox.threaded_application"
        android:allowBackup="true"
        android:fullBackupOnly="true"
        android:fullBackupContent="@xml/auto_backup_rules"
        android:dataExtractionRules="@xml/auto_backup_rules_new"
        android:description="@string/app_description"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/app_splash"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        android:hasFragileUserData="true"
        tools:ignore="GoogleAppIndexingWarning,UnusedAttribute" >
        <uses-library android:name="org.apache.http.legacy" android:required="false"/>
        <activity
            android:name=".intro.intro_activity"
            android:label="@string/app_name_intro"
            android:theme="@style/app_intro"/>

        <activity
            android:name=".ConnectionActivity"
            android:theme="@style/app_theme_black"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>

            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <activity
            android:name=".CvProgrammerActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_cv_programmer"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".WifiActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_wifi"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".ServosActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_servos"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".SensorsActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_sensors"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".LocosActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_locos"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".CurrentsActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_currents"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".TrackManagerActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_track_manager"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".SpeedMatchingActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_speed_matching"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".NeopixelActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_neopixel"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".RosterActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_roster"
            android:theme="@style/app_theme_black" />
        <activity
            android:name=".SpeedTrapActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustNothing"
            android:label="@string/app_name_speed_trap"
            android:theme="@style/app_theme_black" />

        <activity
            android:name=".PreferencesActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:label="@string/app_name_preferences"
            android:theme="@style/app_theme_black" >
        </activity>
        <activity
            android:name=".AboutActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:label="@string/app_name_about"
            android:theme="@style/app_theme_black" >
        </activity>
        <activity
            android:name=".PowerActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:label="@string/app_name_power_control"
            android:theme="@style/app_theme_black" >
        </activity>
        <activity
            android:name=".ReconnectActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:label="@string/app_name_reconnect_status_long"
            android:theme="@style/app_theme_black" >
        </activity>
        <activity
            android:name=".logviewer.ui.LogViewerActivity"
            android:alwaysRetainTaskState="true"
            android:launchMode="singleTop"
            android:label="LogViewerActivity"
            android:theme="@style/app_theme_black" >
        </activity>

        <activity
            android:name=".FileReceiverActivity"
            android:label="EX-Toolbox - Receive File"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <!-- If you want to handle multiple files shared at once -->
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>